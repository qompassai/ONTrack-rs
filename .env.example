# OnTrack-RS — copy this to .env and fill in your values
# The Settings screen in the app will also read/write these keys.

# Google Maps Platform API key
# Enable: Geocoding API, Distance Matrix API, Street View Static API,
# Maps JavaScript API
# https://console.cloud.google.com/google/maps-apis/credentials
GOOGLE_MAPS_API_KEY=""

# OSRM routing server (leave default for free public server,
# override with a self-hosted OSRM for offline/enterprise use)
OSRM_BASE_URL="http://router.project-osrm.org"

# Your ArcGIS Online Web Map item ID — used for ArcGIS FieldMaps deep links
ARCGIS_ITEM_ID=""

# Whisper model size for voice input: tiny | base | small | medium | large
ONTRACK_WHISPER_MODEL="base"

# Optional: absolute path to a pre-downloaded ggml model file
# (skip first-run download from huggingface).
# ONTRACK_WHISPER_MODEL_PATH="/home/you/.cache/ontrack/whisper/ggml-base.bin"
