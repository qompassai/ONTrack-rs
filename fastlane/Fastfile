default_platform(:android)


ONTRACK_AAB_DEFAULT     = "crates/ontrack-mobile/android/app/build/outputs/bundle/release/app-release.aab"
ONTRACK_SYMBOLS_DEFAULT = "crates/ontrack-mobile/android/app/build/outputs/native-debug-symbols/native-debug-symbols.zip"
ONTRACK_PACKAGE         = "com.qompassai.ontrack"

def ensure_aab(root)
  aab = ENV.fetch("ONTRACK_AAB", "#{root}/#{ONTRACK_AAB_DEFAULT}")
  unless ENV["ONTRACK_SKIP_BUILD"] == "1" && File.exist?(aab)
    sh("bash #{root}/scripts/build-android.sh")
  end
  UI.user_error!("AAB still missing at #{aab} after build") unless File.exist?(aab)
  aab
end

def resolve_symbols(root)
  zip = ENV.fetch("ONTRACK_SYMBOLS", "#{root}/#{ONTRACK_SYMBOLS_DEFAULT}")
  File.exist?(zip) ? zip : nil
end

def upload_with_bootstrap_hint(**opts)
  upload_to_play_store(**opts)
rescue => e
  msg = e.message.to_s
  if msg.include?("Package not found") || msg.include?("applicationNotFound")
    UI.error  "==============================================================="
    UI.error  "Play Console app not bootstrapped yet."
    UI.error  ""
    UI.error  "The Play Developer API cannot create apps. You must do a one-"
    UI.error  "time manual upload through the Console UI before fastlane can"
    UI.error  "push releases:"
    UI.error  ""
    UI.error  "  1. https://play.google.com/console  (sign in as phaedrusflow)"
    UI.error  "  2. Create app  ->  Package name: #{ONTRACK_PACKAGE}"
    UI.error  "  3. Testing -> Internal testing -> Create new release"
    UI.error  "  4. Upload the AAB that just built:"
    UI.error  "       #{opts[:aab]}"
    UI.error  "  5. Save the draft (no rollout required)."
    UI.error  ""
    UI.error  "Full runbook: fastlane/INIT.md"
    UI.error  "==============================================================="
  end
  raise
end

platform :android do
  desc "Build ONTrack Android AAB and upload to Closed Testing (API track 'alpha')"
  lane :closed do
    root    = File.expand_path("..", __dir__)
    aab     = ensure_aab(root)
    symbols = resolve_symbols(root)
    UI.message("native debug symbols: #{symbols || '(none found - skipping)'}")

    opts = {
      aab: aab,
      track: ENV.fetch("FASTLANE_TRACK", "alpha"),
      release_status: "draft",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_apk: true
    }
    opts[:mapping] = symbols if symbols
    upload_with_bootstrap_hint(**opts)
  end

  desc "Build ONTrack Android AAB and upload to Internal testing (fastest review path)"
  lane :internal do
    root    = File.expand_path("..", __dir__)
    aab     = ensure_aab(root)
    symbols = resolve_symbols(root)
    UI.message("native debug symbols: #{symbols || '(none found - skipping)'}")

    opts = {
      aab: aab,
      track: "internal",
      release_status: "draft",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_apk: true
    }
    opts[:mapping] = symbols if symbols
    upload_with_bootstrap_hint(**opts)
  end

  desc "Validate service-account credentials only (no build, no AAB needed)"
  lane :check_auth do
    json_key = File.expand_path(
      "#{ENV['XDG_CONFIG_HOME'] || "#{ENV['HOME']}/.config"}/fastlane/google-play-ontrack.json"
    )
    validate_play_store_json_key(json_key: json_key)
  end

  desc "Build + dry-run upload (validate_only). Builds AAB then asks Google to validate it."
  lane :validate do
    root = File.expand_path("..", __dir__)
    aab  = ensure_aab(root)

    upload_with_bootstrap_hint(
      aab: aab,
      track: "internal",
      validate_only: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_apk: true
    )
  end
end
