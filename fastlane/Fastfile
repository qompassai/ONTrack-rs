default_platform(:android)

# Play Developer API track names (per Google):
#   production | beta | alpha | internal
# The Play Console UI calls them:
#   Production | Open testing | Closed testing | Internal testing
# So lane :closed uploads to the API's `alpha` track (= Closed Testing).
# If you've created a *custom* closed-testing track in Console (e.g.
# "qompass-internal"), pass its exact name via the FASTLANE_TRACK env var.
#
# Pre-flight (required ONE TIME before any lane will work):
#   1. Sign in to https://play.google.com/console as phaedrusflow
#   2. Create app -> Application name = ONTrack,
#      Package name = com.qompassai.ontrack  (must match Appfile)
#   3. Manually upload one signed AAB to Internal testing via the Console UI
#      (this is what registers the package_name with the API; fastlane
#      cannot create the app, only update it).
#   4. Grant the fastlane service account Release permissions under
#      Users & permissions in Play Console.
#   See fastlane/INIT.md for the full runbook.

platform :android do
  desc "Build ONTrack Android AAB and upload to Closed Testing (API track 'alpha')"
  lane :closed do
    root = File.expand_path("..", __dir__)
    aab  = ENV.fetch(
      "ONTRACK_AAB",
      "#{root}/crates/ontrack-mobile/android/app/build/outputs/bundle/release/app-release.aab"
    )
    sh("bash #{root}/scripts/build-android.sh") unless
      ENV["ONTRACK_SKIP_BUILD"] == "1" && File.exist?(aab)
    UI.user_error!("AAB missing at #{aab}") unless File.exist?(aab)

    upload_to_play_store(
      aab: aab,
      track: ENV.fetch("FASTLANE_TRACK", "alpha"),
      release_status: "draft",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_apk: true
    )
  end

  desc "Build ONTrack Android AAB and upload to Internal testing (fastest review path)"
  lane :internal do
    root = File.expand_path("..", __dir__)
    aab  = ENV.fetch(
      "ONTRACK_AAB",
      "#{root}/crates/ontrack-mobile/android/app/build/outputs/bundle/release/app-release.aab"
    )
    sh("bash #{root}/scripts/build-android.sh") unless
      ENV["ONTRACK_SKIP_BUILD"] == "1" && File.exist?(aab)
    UI.user_error!("AAB missing at #{aab}") unless File.exist?(aab)

    upload_to_play_store(
      aab: aab,
      track: "internal",
      release_status: "draft",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_apk: true
    )
  end

  desc "Validate service-account credentials only (no build, no AAB needed)"
  lane :check_auth do
    json_key = File.expand_path(
      "#{ENV['XDG_CONFIG_HOME'] || "#{ENV['HOME']}/.config"}/fastlane/google-play-ontrack.json"
    )
    validate_play_store_json_key(json_key: json_key)
  end

  desc "Build + dry-run upload (validate_only). Builds AAB then asks Google to validate it."
  lane :validate do
    root = File.expand_path("..", __dir__)
    aab  = ENV.fetch(
      "ONTRACK_AAB",
      "#{root}/crates/ontrack-mobile/android/app/build/outputs/bundle/release/app-release.aab"
    )

    # Build if the AAB is missing. (skipped if ONTRACK_SKIP_BUILD=1 and the
    # AAB already exists on disk.)
    unless ENV["ONTRACK_SKIP_BUILD"] == "1" && File.exist?(aab)
      sh("bash #{root}/scripts/build-android.sh")
    end

    UI.user_error!("AAB still missing at #{aab} after build") unless File.exist?(aab)

    upload_to_play_store(
      aab: aab,
      track: "internal",
      validate_only: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_apk: true
    )
  end
end
